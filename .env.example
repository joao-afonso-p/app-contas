# Config do Firebase (Consola Firebase → Definições do projeto → As tuas apps → Web app)
# Sem estas variáveis a app funciona só em modo local (IndexedDB).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Códigos de acesso premium (onboarding): lista separada por vírgulas. Cada
# código só pode ser usado uma vez para criar um espaço sincronizado novo (o
# uso fica registado no Firestore, coleção "premiumCodeRedemptions"). Não
# reutilizes um código depois de o partilhares/usares.
VITE_PREMIUM_CODES=
